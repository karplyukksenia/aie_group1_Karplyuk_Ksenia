{
    "experiment_id": "C4",
    "dataset": "STL10",
    "seed": 17,
    "model": {
        "name": "resnet18",
        "pretrained": true,
        "weights": "ResNet18_Weights.DEFAULT",
        "fine_tune": "layer4 + fc",
        "num_classes": 10
    },
    "transforms": {
        "type": "weights.transforms()",
        "normalize_mean": [
            0.485,
            0.456,
            0.406
        ],
        "normalize_std": [
            0.229,
            0.224,
            0.225
        ]
    },
    "training": {
        "optimizer": "Adam",
        "learning_rate": 0.0001,
        "batch_size": 32,
        "num_epochs": 10,
        "loss": "CrossEntropyLoss",
        "weight_decay": 0.0,
        "scheduler": null
    }
}